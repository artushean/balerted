# Comma-separated stock symbols. Leave blank to use default S&P 500 large-cap subset.
SYMBOLS=

# Scanner cadence
CHECK_INTERVAL_MINUTES=30

# Trigger + filter thresholds
DAILY_MOVE_THRESHOLD_PCT=5
INTRADAY_30M_MOVE_THRESHOLD_PCT=3
HIGH_VOLUME_THRESHOLD=2
QUALITY_VOLUME_THRESHOLD=1.5
RELATIVE_STRENGTH_THRESHOLD_PCT=3
MIN_ALERT_SCORE=3

# Alert logging
CSV_LOG_PATH=logs/alerts.csv

# Email config (Gmail: use smtp.gmail.com + app password)
ALERT_EMAIL_TO=recipient@example.com
ALERT_EMAIL_FROM=sender@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_USE_TLS=true
