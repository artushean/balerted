# Comma-separated stock symbols. Leave blank to use default S&P 500 large-cap subset.
SYMBOLS=

# Checks every N minutes
CHECK_INTERVAL_MINUTES=30

# Alert thresholds
DAILY_MOVE_THRESHOLD_PCT=5
SHORT_WINDOW_MINUTES=120
SHORT_MOVE_THRESHOLD_PCT=10

# Email config
ALERT_EMAIL_TO=recipient@example.com
ALERT_EMAIL_FROM=sender@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true
